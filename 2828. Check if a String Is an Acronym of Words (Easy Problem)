class Solution {
public:
    bool isAcronym(vector<string>& words, string s) {
        string result = "";
        int n = words.size();
        for(int i = 0; i < n; i++) {
            int wordLength = words[i].length();
            for(int j = 0; j < 1; j++) {
                result += words[i][j];
                cout << result;
                break;
            }
        }
        if(result == s) {
            return true;
        }
        return false;
    }
};
