class Solution {
public:
    int longestMonotonicSubarray(vector<int>& nums) {
        const int n = nums.size();
        int result = 1;
        int inc = 1, dec = 1;
        for(int i = 1; i < n; i++) {
            if(nums[i] > nums[i - 1]) {
                inc += 1;
                dec = 1;
            } else if(nums[i] < nums[i - 1]) {
                dec += 1;
                inc = 1;
            } else {
                inc = 1;
                dec = 1;
            }
            result = max({result, inc, dec});
        }
        return result;
    }
};
